#!/usr/bin/env python3
"""
Simple Network Packet Sniffer using Scapy
-----------------------------------------
Captures network traffic and displays details such as source/destination IPs,
protocols (TCP, UDP, ICMP), port numbers, and raw payload data.

Note: Root/Administrator privileges are required to capture raw network packets.
"""

import sys
from scapy.all import sniff, IP, TCP, UDP, ICMP, Raw

# Protocol lookup mapping
PROTOCOL_MAP = {
    1: "ICMP",
    6: "TCP",
    17: "UDP"
}

def process_packet(packet):
    """Callback function triggered for each captured packet."""
    
    # Check if the packet has an IP layer
    if packet.haslayer(IP):
        src_ip = packet[IP].src
        dst_ip = packet[IP].dst
        proto_num = packet[IP].proto
        proto_name = PROTOCOL_MAP.get(proto_num, f"Other ({proto_num})")
        
        print("\n" + "=" * 60)
        print(f"[*] New Packet Captured:")
        print(f"    Source IP:      {src_ip}")
        print(f"    Destination IP: {dst_ip}")
        print(f"    Protocol:       {proto_name}")
        
        # Layer 4 details (TCP/UDP)
        if packet.haslayer(TCP):
            print(f"    Source Port:    {packet[TCP].sport}")
            print(f"    Dest Port:      {packet[TCP].dport}")
            
        elif packet.haslayer(UDP):
            print(f"    Source Port:    {packet[UDP].sport}")
            print(f"    Dest Port:      {packet[UDP].dport}")
            
        elif packet.haslayer(ICMP):
            print(f"    ICMP Type:      {packet[ICMP].type}")
            print(f"    ICMP Code:      {packet[ICMP].code}")

        # Payload extraction
        if packet.haslayer(Raw):
            payload = packet[Raw].load
            # Print payload summary (truncated if long)
            print(f"    Payload Data:   {payload[:100]}...")
        else:
            print("    Payload Data:   [No Payload / Encrypted Header Only]")

def main():
    print("=" * 60)
    print("           NETWORK SNIFFER STARTED (Press Ctrl+C to stop)          ")
    print("=" * 60)
    
    try:
        # Sniff packets continuously and process each with process_packet
        sniff(prn=process_packet, store=False)
    except KeyboardInterrupt:
        print("\n[*] Sniffer stopped by user.")
        sys.exit(0)
    except PermissionError:
        print("\n[!] Error: Permission denied. Please run this script with root/administrator privileges.")
        sys.exit(1)

if __name__ == "__main__":
    main()
